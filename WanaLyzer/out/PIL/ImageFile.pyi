class Parser:
    incremental: Incomplete
    image: Incomplete
    data: Incomplete
    decoder: Incomplete
    offset: int
    finished: int
    def reset(self) -> None: ...
    decode: Incomplete
    def feed(self, data) -> None: ...
    def __enter__(self): ...
    def __exit__(self, *args) -> None: ...
    def close(self): ...

class PyCodecState:
    xsize: int
    ysize: int
    xoff: int
    yoff: int
    def __init__(self) -> None: ...
    def extents(self): ...

class PyCodec:
    im: Incomplete
    state: Incomplete
    fd: Incomplete
    mode: Incomplete
    def __init__(self, mode, *args) -> None: ...
    args: Incomplete
    def init(self, args) -> None: ...
    def cleanup(self) -> None: ...
    def setfd(self, fd) -> None: ...
    def setimage(self, im, extents: Incomplete | None = None) -> None: ...

class PyDecoder(PyCodec):
    @property
    def pulls_fd(self): ...
    def decode(self, buffer) -> None: ...
    def set_as_raw(self, data, rawmode: Incomplete | None = None) -> None: ...

class PyEncoder(PyCodec):
    @property
    def pushes_fd(self): ...
    def encode(self, bufsize) -> None: ...
    def encode_to_pyfd(self): ...
    def encode_to_file(self, fh, bufsize): ...
